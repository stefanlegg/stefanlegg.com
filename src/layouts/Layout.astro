---
import { ViewTransitions } from "astro:transitions";
import SEOTags from "@/components/seo/SEOTags.astro";
import type { HeadTags } from "@/utils/types/HeadTags";
import Header from "../components/Header.astro";
import KonamiGame from "../components/KonamiGame.astro";

import "@/styles/tailwind.css";
import "@/styles/post.css";

export type Props = HeadTags;

const { ...headTags } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <SEOTags {...headTags} />
  <body>
    <canvas class="stars" id="stars" transition:persist></canvas>
    <div class="grain" transition:persist></div>
    <div class="vignette" transition:persist></div>

    <div class="page">
      <Header />
      <main>
        <slot />
      </main>
    </div>

    <div class="scroll-secret">
      <span>huh, still scrolling? try another method...</span>
      <span class="hint">↑↑↓↓←→←→BA</span>
    </div>

    <KonamiGame />
  </body>
  <ViewTransitions />

  <script>
    import { initStarfield } from '@/lib/starfield';
    import { initScrollSecret } from '@/lib/scroll-secret';

    document.addEventListener('astro:page-load', () => {
      const canvas = document.getElementById('stars') as HTMLCanvasElement;
      if (canvas) initStarfield(canvas);

      const secret = document.querySelector('.scroll-secret') as HTMLElement;
      if (secret) initScrollSecret(secret);

      // 🤫
      console.log('%c// TODO: remove konami code before launch 🤫', 'color: #a080c4');
    });
  </script>
</html>

<style is:global>
  /* Star field canvas */
  .stars {
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
  }

  /* Vignette */
  .vignette {
    position: fixed; inset: 0; z-index: 9996; pointer-events: none;
    background: radial-gradient(ellipse at center, transparent 45%, rgba(6, 7, 12, 0.5) 80%, rgba(6, 7, 12, 0.8) 100%);
  }

  /* Subtle grain */
  .grain {
    position: fixed; inset: 0; z-index: 9998; pointer-events: none;
    opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px;
  }

  .page {
    max-width: 840px; margin: 0 auto;
    padding: 0 32px 120px; position: relative; z-index: 1;
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 600px) {
    .page { padding: 0 20px; }
  }

  /* Hide overscroll hint on touch/mobile devices */
  @media (pointer: coarse), (hover: none) {
    .scroll-secret { display: none; }
  }

  /* Scroll secret */
  .scroll-secret {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    text-align: center;
    padding: 30px 20px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: rgba(208, 216, 234, 0.25);
    letter-spacing: 1px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    pointer-events: none;
    user-select: none;
    opacity: 0;
    transform: translateY(100%);
    transition: opacity 1.5s ease, transform 0.8s ease;
    z-index: 10;
  }
  .scroll-secret .hint {
    font-size: 11px;
    letter-spacing: 3px;
  }
  .scroll-secret.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
