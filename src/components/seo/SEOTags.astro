---
import { SITE_URL } from "@/data/config";
import type { HeadTags } from "@/utils/types/HeadTags";
import { SEO } from "astro-seo";

type Props = HeadTags;

const { title, description, noindex, og, canonical, article } = Astro.props;

const DEFAULT_TITLE_PAGE = "Stefan Legg | Software Engineer";
const DEFAULT_DESCRIPTION_PAGE = "Stefan Legg is a software engineer with 15+ years of experience building for the web. Currently at Shopify, focused on React, TypeScript, and making commerce better for everyone.";
const DEFAULT_URL_SITE = SITE_URL;

// Build canonical URL
const canonicalURL = canonical 
  ? new URL(canonical, DEFAULT_URL_SITE).href 
  : new URL(Astro.url.pathname, DEFAULT_URL_SITE).href;

const openGraph = {
	title: title || og?.title || DEFAULT_TITLE_PAGE,
	type: og?.type || "website",
	image: og?.image || "/og-image.png",
	alt: og?.alt || "Stefan Legg portfolio image",
	url: canonicalURL,
	description: og?.description || description || DEFAULT_DESCRIPTION_PAGE,
};

// Person schema (for homepage/general pages)
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Stefan Legg",
  "url": DEFAULT_URL_SITE,
  "jobTitle": "Software Engineer",
  "worksFor": {
    "@type": "Organization",
    "name": "Shopify",
    "url": "https://shopify.com"
  },
  "sameAs": [
    "https://twitter.com/stefanlegg",
    "https://github.com/stefanlegg",
    "https://linkedin.com/in/stefanlegg"
  ]
};

// WebSite schema
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Stefan Legg",
  "url": DEFAULT_URL_SITE,
  "description": DEFAULT_DESCRIPTION_PAGE,
  "author": {
    "@type": "Person",
    "name": "Stefan Legg"
  }
};

// Article schema (only for blog posts)
const articleSchema = article ? {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description || DEFAULT_DESCRIPTION_PAGE,
  "image": openGraph.image.startsWith('http') ? openGraph.image : `${DEFAULT_URL_SITE}${openGraph.image}`,
  "datePublished": article.publishedTime,
  "dateModified": article.modifiedTime || article.publishedTime,
  "author": {
    "@type": "Person",
    "name": article.author || "Stefan Legg",
    "url": DEFAULT_URL_SITE
  },
  "publisher": {
    "@type": "Person",
    "name": "Stefan Legg",
    "url": DEFAULT_URL_SITE
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL
  }
} : null;
---

<head>
  <SEO
    charset="UTF-8"
    title={title || DEFAULT_TITLE_PAGE}
    description={description || DEFAULT_DESCRIPTION_PAGE}
    noindex={noindex || false}
    canonical={canonicalURL}
    openGraph={{
      basic: {
        title: openGraph.title,
        type: openGraph.type,
        image: openGraph.image,
        url: openGraph.url,
      },
      image: {
        alt: openGraph.alt,
      },
      optional: {
        description: openGraph.description,
      },
    }}
    twitter={{
      creator: "@stefanlegg",
    }}
    extend={{
      link: [
        { rel: "icon", type: "image/svg+xml", href: "/favicon.svg" },
        { rel: "sitemap", href: "/sitemap-index.xml" },
      ],
      meta: [
        { name: "viewport", content: "width=device-width, initial-scale=1" },
        { name: "generator", content: Astro.generator },
        { name: "author", content: "Stefan Legg" },
        {
          name: "twitter:image",
          content: openGraph.image,
        },
        { name: "twitter:card", content: "summary_large_image" },
        { name: "twitter:title", content: openGraph.title },
        { name: "twitter:description", content: openGraph.description },
        { name: "twitter:site", content: "@stefanlegg" },
        ...(article ? [
          { property: "article:published_time", content: article.publishedTime },
          { property: "article:author", content: article.author || "Stefan Legg" },
        ] : []),
      ],
    }}
  />
  
  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  {articleSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  )}
  
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=JetBrains+Mono:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
